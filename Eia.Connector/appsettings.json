{
    "EiaConnector": {
        "BaseUrl": "https://api.eia.gov/v2/nuclear-outages/us-nuclear-outages/data",
        "PageSize": 5000,
        "RetryCount": 2,
        "TimeoutSeconds": 30,
        "DataFields": "capacity,outage,percentOutage"
    },
    "Output": {
        "ParquetPath": "data/nuclear_outages_raw.parquet",
        "CheckpointPath": "data/checkpoint.json"
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning"
        }
    }
}